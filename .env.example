# Switchboard environment contract
# This file reflects actual runtime usage in the current codebase.

# Required
DATA_DIR=/var/lib/switchboard

# Recommended runtime variables
PORT=20128
NODE_ENV=production

# Recommended security and ops variables
API_KEY_SECRET=endpoint-proxy-api-key-secret
MACHINE_ID_SALT=endpoint-proxy-salt
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true
# Non-loopback /v1 requires a gateway API key when true (default). Set false only if you intentionally expose LAN access.
REQUIRE_API_KEY=true
# Bind address: use 127.0.0.1 for local-only (CLI default). 0.0.0.0 exposes on LAN.
# HOSTNAME=127.0.0.1

# Must point to this running instance so internal sync jobs can call /api/sync/cloud.
# Server-side preferred variables:
BASE_URL=http://localhost:20128
# Backward-compatible/public variables:
NEXT_PUBLIC_BASE_URL=http://localhost:20128

# Optional outbound proxy variables for upstream provider calls
# Lowercase variants are also supported: http_proxy, https_proxy, all_proxy, no_proxy
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# Optional compatible/provider overrides
# OPENAI_API_KEY=
# AZURE_ENDPOINT=
# AZURE_DEPLOYMENT=
# AZURE_API_VERSION=
# AZURE_ORGANIZATION=
# GLM_API_ENDPOINT=
# GLM_API_KEY=
# GLM_API_MODEL=
# GLM_MAX_TOKENS=
# GLM_TEMPERATURE=
# KIMI_CODING_OAUTH_CLIENT_ID=
# HEADROOM_URL=

# Optional runtime tuning
# LOG_LEVEL=info
# KEEP_ALIVE_TIMEOUT=65000
# USAGE_HISTORY_MAX=10000
# TRANSLATE_BATCH_SIZE=50
# OBSERVABILITY_BATCH_SIZE=50
# OBSERVABILITY_FLUSH_INTERVAL_MS=5000
# OBSERVABILITY_MAX_BUFFER=1000
# OBSERVABILITY_MAX_JSON_SIZE=1048576
# OBSERVABILITY_MAX_RECORDS=10000
# SWITCHBOARD_LOCAL_PEERS=172.18.0.1
# SWITCHBOARD_PROXY_CLIENT_MAX_BODY_SIZE=128mb
# NEXT_PUBLIC_CLOUD_URL=

# Currently unused by application runtime (kept as reference)
# INSTANCE_NAME=switchboard
