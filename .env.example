# Switchboard environment contract
# Full reference and precedence rules: docs/ENVIRONMENT.md

# Storage and listener
DATA_DIR=/var/lib/switchboard
PORT=20128
NODE_ENV=production
# CLI launchers default to loopback. Uncomment only for intentional LAN/container exposure.
# HOSTNAME=127.0.0.1

# Security and operations
# The dashboard has no authentication; keep it on loopback or behind a trusted authenticated proxy.
# Omit these to generate stable per-install secrets under DATA_DIR/auth.
# API_KEY_SECRET=
# MACHINE_ID_SALT=
# Non-loopback /v1 traffic requires an active Switchboard API key by default.
REQUIRE_API_KEY=true
ENABLE_REQUEST_LOGS=false
ENABLE_TRANSLATOR=false
LOG_LEVEL=info

# Standard outbound proxy variables; lowercase forms are also supported.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# Request and streaming timeouts (milliseconds)
# STREAM_FIRST_CHUNK_TIMEOUT_MS=200000
# STREAM_STALL_TIMEOUT_MS=360000
# FETCH_CONNECT_TIMEOUT_MS=60000
# GEMINI_NATIVE_TTS_FETCH_TIMEOUT_MS=45000

# Request-detail observability defaults. Persisted dashboard settings win when present.
OBSERVABILITY_ENABLED=true
# OBSERVABILITY_MAX_RECORDS=1000
# OBSERVABILITY_BATCH_SIZE=20
# OBSERVABILITY_FLUSH_INTERVAL_MS=5000
# OBSERVABILITY_MAX_JSON_SIZE=5
# OBSERVABILITY_MAX_BUFFER=5000
# USAGE_HISTORY_MAX=50000

# Optional compatible/provider fallbacks
# OPENAI_API_KEY=
# AZURE_ENDPOINT=
# AZURE_DEPLOYMENT=
# AZURE_API_VERSION=
# AZURE_ORGANIZATION=
# KIMI_CODING_OAUTH_CLIENT_ID=
# HEADROOM_URL=http://localhost:8787

# Container/local-request boundary
# Compose sets this to its fixed gateway address.
# SWITCHBOARD_LOCAL_PEERS=172.30.0.1
# SWITCHBOARD_PROXY_CLIENT_MAX_BODY_SIZE=128mb

# Diagnostics (set to 1 only while troubleshooting)
# CURSOR_STREAM_DEBUG=1
# CURSOR_PROTOBUF_DEBUG=1
# DEBUG_MITM=1
