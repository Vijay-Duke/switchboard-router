{
  "name": "switchboard-docs",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "check:markdown": "node scripts/check-markdown.mjs",
    "test": "node --test tests/*.test.mjs",
    "build": "npm run check:markdown && next build",
    "start": "next start -p 3001",
    "deploy": "npm run build && npx wrangler pages deploy out --project-name=switchboard-docs --commit-dirty=true"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "tailwindcss": "^4.2.0"
  }
}
